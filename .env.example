
#  Конфигурация бота — скопируй в .env и заполни


# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# SQLite (путь к файлу БД)
DATABASE_PATH=finance.db

# OpenAI API Key (для голосового ввода через Whisper)
# Если не нужен голосовой ввод — оставь пустым
OPENAI_API_KEY=sk-...

# Валюта по умолчанию: KGS | RUB | USD | EUR | KZT
DEFAULT_CURRENCY=KGS

# Таймзона
DEFAULT_TIMEZONE=Asia/Bishkek

# TTL кэша отчётов в Redis (секунды)
REPORT_CACHE_TTL=300
